# ═══════════════════════════════════════════════════════════
# PUSPALOY – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore
# ═══════════════════════════════════════════════════════════

# ── Firebase (Public — safe to expose in browser) ──────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Admin ──────────────────────────────────────────────────
# Super Admin Firebase UID (get from Firebase Auth console)
VITE_SUPER_ADMIN_UID=your_super_admin_firebase_uid

# ── Analytics (optional) ───────────────────────────────────
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_CLARITY_PROJECT_ID=your_clarity_id

# ── App URL ────────────────────────────────────────────────
VITE_APP_URL=https://puspaloy.netlify.app

# ══════════════════════════════════════════════════════════════
# LOCAL DEV ONLY — Zyntra AI (never committed, .env is gitignored)
# In PRODUCTION, set these as Netlify Environment Variables instead.
# Netlify Dashboard → Site settings → Environment variables
# ══════════════════════════════════════════════════════════════

# Used ONLY in local dev (npm run dev) as fallback when netlify dev isn't running.
# In production, the Netlify Function reads OPENROUTER_API_KEY (no VITE_ prefix).
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# ── SERVER-SIDE ONLY — Set in Netlify Dashboard, NOT here ──
# OPENROUTER_API_KEY=your_openrouter_key_here   ← Netlify env var (no VITE_ prefix)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token    ← Netlify env var
# TELEGRAM_CHAT_ID=your_telegram_chat_id        ← Netlify env var
# RESEND_API_KEY=your_resend_api_key            ← Netlify env var
# ADMIN_EMAIL=orders@puspaloy.com               ← Netlify env var
# STEADFAST_API_KEY=your_steadfast_api_key      ← Steadfast Courier (no VITE_ prefix — server only)
# STEADFAST_SECRET_KEY=your_steadfast_secret_key ← Steadfast Courier (no VITE_ prefix — server only)
