rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper ───────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && 
             firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/mp4');
    }

    function isWithinSizeLimit(maxMB) {
      return request.resource.size <= maxMB * 1024 * 1024;
    }

    // ─── Product images ───────────────────────────────────────
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() &&
        (isImage() && isWithinSizeLimit(10));
    }

    // ─── Content / CMS images ─────────────────────────────────
    match /content/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() &&
        (isImage() && isWithinSizeLimit(10));
    }

    // ─── Admin avatars ────────────────────────────────────────
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() &&
        isImage() && isWithinSizeLimit(2);
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
